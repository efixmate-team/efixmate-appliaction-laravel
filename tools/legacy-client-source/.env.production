# =============================================================================
# eFixMate — root .env.production  (NEVER commit — gitignored)
# =============================================================================
#   Copy values from here to your server at deploy time, or pipe into
#   docker-compose: docker compose --env-file .env.production -f docker-compose.prod.yml up -d
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
DB_USER=admin
DB_PASSWORD=password123
DB_NAME=fixmate_db
DB_PORT=5433

# Full DSN used by server startup check
DATABASE_URL=postgresql://admin:replace_me_db_password@localhost:5433/fixmate_db

# -----------------------------------------------------------------------------
# BACKEND
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# JWT Secrets — generate each with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=c527b7677bc203bc1a8eaef61fc462cdda05397772471e2f5382bf1f45938e83
ADMIN_JWT_SECRET=c527b7677bc203bc1a8eaef61fc462cdda05397772471e2f5382bf1f45938e83
USER_JWT_SECRET=c527b7677bc203bc1a8eaef61fc462cdda05397772471e2f5382bf1f45938e83
TECHNICIAN_JWT_SECRET=replace_me_technician_jwt_secret_64_chars_min

SECRET_KEY=replace_me_secret_key_64_chars_min
FIXMATE_INTERNAL_API_KEY=replace_me_internal_api_key_32_chars_min

# TOTP / admin-security key (AES-256-GCM) — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECURITY_KEY=replace_me_admin_security_key_32_chars_min

# -----------------------------------------------------------------------------
# REDIS (required for queue-worker + realtime)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true
SOCKET_ENABLED=true

# -----------------------------------------------------------------------------
# PUBLIC URLS
# -----------------------------------------------------------------------------
FRONTEND_URL=https://efixmate.com
APP_URL=https://efixmate.com
PUBLIC_URL=https://efixmate.com

CORS_ORIGINS=https://efixmate.com
TRUST_PROXY=1
ENABLE_REQUEST_LOGS=false
LOG_LEVEL=info

# Upload URLs — served as https://efixmate.com/api/uploads/...
UPLOADS_PUBLIC_PREFIX=/api
API_BASE_PATH=/api
UPLOAD_RELATIVE_URLS=false

# -----------------------------------------------------------------------------
# FRONTEND (Next.js — baked in at build time)
# -----------------------------------------------------------------------------
CLIENT_PORT=3000

# Internal Docker networking — Next.js → Express (no /api prefix inside Docker)
BACKEND_INTERNAL_URL=http://server:5000
BACKEND_URL=http://server:5000

# Browser-side API base (baked into the Next.js bundle)
NEXT_PUBLIC_API_URL=https://efixmate.com/api

# -----------------------------------------------------------------------------
# GOOGLE MAPS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyBBf5sA7vzuGN-caOTsjqQDqHwkd8xNP08
GOOGLE_MAPS_API_KEY=AIzaSyBBf5sA7vzuGN-caOTsjqQDqHwkd8xNP08

# -----------------------------------------------------------------------------
# PAYMENT GATEWAYS
# -----------------------------------------------------------------------------
# Leave PAYMENT_MODE blank (or remove) for real payments; set to "mock" for staging
PAYMENT_MODE=

# Razorpay — replace with LIVE keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_replace_me
RAZORPAY_KEY_SECRET=replace_me_razorpay_live_secret
PAYMENT_WEBHOOK_SECRET=replace_me_webhook_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_replace_me

# Cashfree — replace with LIVE keys from https://merchant.cashfree.com
CASHFREE_APP_ID=replace_me_cashfree_live_app_id
CASHFREE_SECRET_KEY=replace_me_cashfree_live_secret
CASHFREE_ENV=production

# Stripe (uncomment when ready)
# STRIPE_SECRET_KEY=sk_live_replace_me
# STRIPE_PUBLISHABLE_KEY=pk_live_replace_me

# PhonePe (uncomment when ready)
# PHONEPE_MERCHANT_ID=replace_me
# PHONEPE_SALT_KEY=replace_me
# PHONEPE_SALT_INDEX=1
# PHONEPE_ENV=production

# -----------------------------------------------------------------------------
# MSG91 SMS / OTP
# -----------------------------------------------------------------------------
MSG91_AUTH_KEY=525736AVBUrgF0EM6a2ae8b2P1
MSG91_TEMPLATE_ID=6a2ae3fd4b5a342dd20f4dc2
MSG91_SENDER_ID=EFXMTE

# Transactional SMS templates (booking lifecycle)
MSG91_TMPL_BOOKING_CONFIRMED=replace_me_booking_confirmed_tmpl
MSG91_TMPL_TECH_ASSIGNED=replace_me_tech_assigned_tmpl
MSG91_TMPL_JOB_COMPLETED=replace_me_job_completed_tmpl
MSG91_TMPL_BOOKING_CANCELLED=replace_me_booking_cancelled_tmpl
MSG91_TMPL_RETENTION_NUDGE=replace_me_retention_nudge_tmpl

# -----------------------------------------------------------------------------
# FIREBASE / FCM (push notifications)
# -----------------------------------------------------------------------------
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste entire JSON minified as one line:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"efixmate-pvt-ldt",...}
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BFHRob-PjdfAOHWy4B2W4SllxAmUKBT16-HbI9nIW5_3wSHIw3Tva5PNZgJZn2FrnTAowdOUQSVoxwBo37oT_Bc

# -----------------------------------------------------------------------------
# LOYALTY / RETENTION
# -----------------------------------------------------------------------------
LOYALTY_POINTS_PER_100=1
RETENTION_DORMANT_DAYS=30
RETENTION_NUDGE_COOLDOWN=14
RETENTION_BATCH_SIZE=200

# Sentry error tracking (uncomment when DSN is ready)
# SENTRY_DSN=https://replace_me@sentry.io/project-id
